[mysqld]

# ============================================
# MySQL 5.7/8.0 针对 2核4G 服务器优化配置
# 适用环境：RuoYi 项目生产部署
# ============================================

# -------------------- 基础配置 --------------------
# InnoDB 缓冲池大小（建议设为物理内存的50%-70%）
innodb_buffer_pool_size = 512M
# InnoDB 日志文件大小
innodb_log_file_size = 128M
# 日志刷新策略：0每秒刷一次 1每次提交刷 2每次提交写到OS缓存（推荐）
innodb_flush_log_at_trx_commit = 2
# 数据文件刷新方式：O_DIRECT避免双重缓存
innodb_flush_method = O_DIRECT
# 最大连接数
max_connections = 200

# -------------------- 查询优化 --------------------
# 开启慢查询日志
slow_query_log = 1
# 慢查询阈值（秒）
long_query_time = 1
# 慢查询日志文件
slow_query_log_file = /var/log/mysql/slow-query.log

# -------------------- 连接超时 --------------------
# 非交互连接超时（秒）
wait_timeout = 600
# 交互式连接超时（秒）
interactive_timeout = 600

# -------------------- 表缓存 --------------------
# 表缓存数量
table_open_cache = 512
# 表定义缓存
table_definition_cache = 512

# -------------------- 排序缓冲 --------------------
# 排序缓冲区大小
sort_buffer_size = 2M
# 连接缓冲区大小
join_buffer_size = 2M
# 读缓冲区大小
read_buffer_size = 2M

# -------------------- 线程配置 --------------------
# InnoDB 并发线程数
innodb_thread_concurrency = 4
# 读写IO线程数
innodb_read_io_threads = 2
innodb_write_io_threads = 2

# -------------------- 其他优化 --------------------
# 字符集
character-set-server = utf8mb4
collation-server = utf8mb4_general_ci
# 跳过域名解析（加速连接）
skip-name-resolve
# 最大允许包大小
max_allowed_packet = 64M
# 临时表大小
tmp_table_size = 32M
max_heap_table_size = 32M

[client]
default-character-set = utf8mb4
