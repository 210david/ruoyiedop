<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysAlarmLogMapper">

	<resultMap type="SysAlarmLog" id="SysAlarmLogResult">
		<id     property="id"           column="id"            />
		<result property="alarmType"    column="alarm_type"    />
		<result property="alarmLevel"   column="alarm_level"   />
		<result property="alarmTitle"   column="alarm_title"   />
		<result property="alarmDetail"  column="alarm_detail"  />
		<result property="status"       column="status"        />
		<result property="createTime"   column="create_time"   />
		<result property="handleTime"   column="handle_time"   />
		<result property="handleBy"     column="handle_by"     />
	</resultMap>

	<sql id="selectAlarmLogVo">
        select id, alarm_type, alarm_level, alarm_title, alarm_detail, status, create_time, handle_time, handle_by
        from sys_alarm_log
    </sql>

	<insert id="insertAlarmLog" parameterType="SysAlarmLog">
		insert into sys_alarm_log(alarm_type, alarm_level, alarm_title, alarm_detail, status, create_time)
        values (#{alarmType}, #{alarmLevel}, #{alarmTitle}, #{alarmDetail}, #{status}, sysdate())
	</insert>

	<select id="selectAlarmLogList" parameterType="SysAlarmLog" resultMap="SysAlarmLogResult">
		<include refid="selectAlarmLogVo"/>
		<where>
			<if test="alarmType != null and alarmType != ''">
				AND alarm_type = #{alarmType}
			</if>
			<if test="alarmLevel != null and alarmLevel != ''">
				AND alarm_level = #{alarmLevel}
			</if>
			<if test="alarmTitle != null and alarmTitle != ''">
				AND alarm_title like concat('%', #{alarmTitle}, '%')
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
			<if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
				AND create_time &gt;= #{params.beginTime}
			</if>
			<if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
				AND create_time &lt;= #{params.endTime}
			</if>
		</where>
		order by id desc
	</select>

	<select id="selectAlarmLogById" parameterType="Long" resultMap="SysAlarmLogResult">
		<include refid="selectAlarmLogVo"/>
		where id = #{id}
	</select>

	<delete id="deleteAlarmLogByIds" parameterType="Long">
 		delete from sys_alarm_log where id in
 		<foreach collection="array" item="id" open="(" separator="," close=")">
 			#{id}
        </foreach>
 	</delete>

	<update id="updateAlarmLogStatus" parameterType="SysAlarmLog">
		update sys_alarm_log
		set status = #{status}, handle_time = #{handleTime}, handle_by = #{handleBy}
		where id = #{id}
	</update>

	<update id="cleanAlarmLog">
        truncate table sys_alarm_log
    </update>

</mapper>
