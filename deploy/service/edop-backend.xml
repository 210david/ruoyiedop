<service>
  <id>EDOP-Backend</id>
  <name>EDOP 后端服务</name>
  <description>企业数字化运营平台 - Spring Boot 后端服务 (端口8004)</description>
  
  <executable>%JAVA_HOME%\bin\java.exe</executable>
  <arguments>-Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai -Xms512m -Xmx1024m -XX:MetaspaceSize=128m -XX:MaxMetaspaceSize=512m -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=D:\EDOP\app\logs -jar ruoyi-admin.jar</arguments>
  
  <workingdirectory>D:\EDOP\app</workingdirectory>
  
  <logpath>D:\EDOP\app\logs\winsw</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>
  
  <onfailure action="restart" delay="10 sec"/>
  <onfailure action="restart" delay="20 sec"/>
  <onfailure action="restart" delay="60 sec"/>
  
  <startmode>Automatic</startmode>
  <delayedstart>true</delayedstart>
</service>
