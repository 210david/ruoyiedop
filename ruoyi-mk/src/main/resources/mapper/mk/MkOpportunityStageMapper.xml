<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mk.mapper.MkOpportunityStageMapper">

    <resultMap type="MkOpportunityStage" id="MkOpportunityStageResult">
        <result property="stageId"         column="stage_id"/>
        <result property="stageCode"       column="stage_code"/>
        <result property="stageName"       column="stage_name"/>
        <result property="sort"            column="sort"/>
        <result property="winRate"         column="win_rate"/>
        <result property="maxDays"         column="max_days"/>
        <result property="requiredFields"  column="required_fields"/>
        <result property="status"          column="status"/>
        <result property="createBy"        column="create_by"/>
        <result property="createTime"      column="create_time"/>
        <result property="updateBy"        column="update_by"/>
        <result property="updateTime"      column="update_time"/>
        <result property="remark"          column="remark"/>
    </resultMap>

    <sql id="selectStageVo">
        SELECT stage_id, stage_code, stage_name, sort, win_rate, max_days, required_fields, status,
               create_by, create_time, update_by, update_time, remark
        FROM mk_opportunity_stage
    </sql>

    <select id="selectStageList" parameterType="MkOpportunityStage" resultMap="MkOpportunityStageResult">
        <include refid="selectStageVo"/>
        <where>
            <if test="stageName != null and stageName != ''"> AND stage_name LIKE CONCAT('%', #{stageName}, '%')</if>
            <if test="status != null and status != ''"> AND status = #{status}</if>
        </where>
        ORDER BY sort
    </select>

    <select id="selectStageById" parameterType="Long" resultMap="MkOpportunityStageResult">
        <include refid="selectStageVo"/> WHERE stage_id = #{stageId}
    </select>

    <insert id="insertStage" parameterType="MkOpportunityStage" useGeneratedKeys="true" keyProperty="stageId">
        INSERT INTO mk_opportunity_stage (stage_code, stage_name, sort, win_rate, max_days, required_fields,
            status, create_by, create_time, remark)
        VALUES (#{stageCode}, #{stageName}, #{sort}, #{winRate}, #{maxDays}, #{requiredFields},
            #{status}, #{createBy}, sysdate(), #{remark})
    </insert>

    <update id="updateStage" parameterType="MkOpportunityStage">
        UPDATE mk_opportunity_stage
        <set>
            <if test="stageCode != null and stageCode != ''">stage_code = #{stageCode},</if>
            <if test="stageName != null and stageName != ''">stage_name = #{stageName},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="winRate != null">win_rate = #{winRate},</if>
            <if test="maxDays != null">max_days = #{maxDays},</if>
            <if test="requiredFields != null">required_fields = #{requiredFields},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        WHERE stage_id = #{stageId}
    </update>

    <delete id="deleteStageByIds" parameterType="Long">
        DELETE FROM mk_opportunity_stage WHERE stage_id IN
        <foreach item="stageId" collection="array" open="(" separator="," close=")">#{stageId}</foreach>
    </delete>

</mapper>
