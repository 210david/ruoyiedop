<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mk.mapper.MkCustomerTagMapper">

    <resultMap type="MkCustomerTag" id="MkCustomerTagResult">
        <result property="tagId"      column="tag_id"/>
        <result property="tagName"    column="tag_name"/>
        <result property="tagType"    column="tag_type"/>
        <result property="tagColor"   column="tag_color"/>
        <result property="sort"       column="sort"/>
        <result property="status"     column="status"/>
        <result property="createBy"   column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy"   column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark"     column="remark"/>
    </resultMap>

    <sql id="selectTagVo">
        SELECT tag_id, tag_name, tag_type, tag_color, sort, status, create_by, create_time,
               update_by, update_time, remark
        FROM mk_customer_tag
    </sql>

    <select id="selectTagList" parameterType="MkCustomerTag" resultMap="MkCustomerTagResult">
        <include refid="selectTagVo"/>
        <where>
            <if test="tagName != null and tagName != ''"> AND tag_name LIKE CONCAT('%', #{tagName}, '%')</if>
            <if test="tagType != null and tagType != ''"> AND tag_type = #{tagType}</if>
            <if test="status != null and status != ''"> AND status = #{status}</if>
        </where>
        ORDER BY sort
    </select>

    <select id="selectTagById" parameterType="Long" resultMap="MkCustomerTagResult">
        <include refid="selectTagVo"/> WHERE tag_id = #{tagId}
    </select>

    <insert id="insertTag" parameterType="MkCustomerTag" useGeneratedKeys="true" keyProperty="tagId">
        INSERT INTO mk_customer_tag (tag_name, tag_type, tag_color, sort, status, create_by, create_time, remark)
        VALUES (#{tagName}, #{tagType}, #{tagColor}, #{sort}, #{status}, #{createBy}, sysdate(), #{remark})
    </insert>

    <update id="updateTag" parameterType="MkCustomerTag">
        UPDATE mk_customer_tag
        <set>
            <if test="tagName != null and tagName != ''">tag_name = #{tagName},</if>
            <if test="tagType != null">tag_type = #{tagType},</if>
            <if test="tagColor != null">tag_color = #{tagColor},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        WHERE tag_id = #{tagId}
    </update>

    <delete id="deleteTagByIds" parameterType="Long">
        DELETE FROM mk_customer_tag WHERE tag_id IN
        <foreach item="tagId" collection="array" open="(" separator="," close=")">#{tagId}</foreach>
    </delete>

</mapper>
