<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.dms.mapper.DmsRepairFaqMapper">
    <resultMap type="DmsRepairFaq" id="DmsRepairFaqResult">
        <result property="faqId" column="faq_id"/>
        <result property="question" column="question"/>
        <result property="answer" column="answer"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="keywords" column="keywords"/>
        <result property="viewCount" column="view_count"/>
        <result property="status" column="status"/>
        <result property="delFlag" column="del_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectFaqVo">
        SELECT faq_id, question, answer, category_id, category_name, keywords, view_count,
               status, del_flag, create_by, create_time, update_by, update_time, remark
        FROM dms_repair_faq
    </sql>

    <select id="selectFaqList" parameterType="DmsRepairFaq" resultMap="DmsRepairFaqResult">
        <include refid="selectFaqVo"/>
        <where> del_flag = '0'
            <if test="question != null and question != ''"> AND question LIKE CONCAT('%', #{question}, '%')</if>
            <if test="keywords != null and keywords != ''"> AND keywords LIKE CONCAT('%', #{keywords}, '%')</if>
            <if test="status != null and status != ''"> AND status = #{status}</if>
        </where>
        ORDER BY faq_id DESC
    </select>

    <select id="selectFaqById" parameterType="Long" resultMap="DmsRepairFaqResult">
        <include refid="selectFaqVo"/> WHERE faq_id = #{faqId}
    </select>

    <insert id="insertFaq" parameterType="DmsRepairFaq" useGeneratedKeys="true" keyProperty="faqId">
        INSERT INTO dms_repair_faq (question, answer, category_id, category_name, keywords, view_count, status, create_by, create_time, remark)
        VALUES (#{question}, #{answer}, #{categoryId}, #{categoryName}, #{keywords}, 0, #{status}, #{createBy}, sysdate(), #{remark})
    </insert>

    <update id="updateFaq" parameterType="DmsRepairFaq">
        UPDATE dms_repair_faq
        <set>
            <if test="question != null and question != ''">question = #{question},</if>
            <if test="answer != null">answer = #{answer},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="categoryName != null">category_name = #{categoryName},</if>
            <if test="keywords != null">keywords = #{keywords},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        WHERE faq_id = #{faqId}
    </update>

    <delete id="deleteFaqByIds" parameterType="Long">
        UPDATE dms_repair_faq SET del_flag = '2' WHERE faq_id IN
        <foreach item="faqId" collection="array" open="(" separator="," close=")">#{faqId}</foreach>
    </delete>
</mapper>
